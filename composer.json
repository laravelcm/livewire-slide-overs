{
  "name": "laravelcm/livewire-slide-overs",
  "description": "Livewire component that provides drawers (slide overs) that support multiple children while maintaining state.",
  "keywords": [
    "laravel",
    "slide-overs",
    "livewire"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Arthur Monney",
      "email": "monneylobe@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "livewire/livewire": "^3.7|^4.2",
    "spatie/laravel-package-tools": "^1.9"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "laravel/pint": "^1.1",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-livewire": "^4.0",
    "phpstan/phpstan": "^2.1.27"
  },
  "autoload": {
    "psr-4": {
      "Laravelcm\\LivewireSlideOvers\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Laravelcm\\LivewireSlideOvers\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "pint",
    "test:lint": "pint --test",
    "test:types": "phpstan analyse --ansi",
    "test": "pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Laravelcm\\LivewireSlideOvers\\LivewireSlideOverServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
